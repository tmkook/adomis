{
  "name": "adomis",
  "description": "amis admin framework",
  "version": "0.0.1",
  "engines": {
    "node": ">=20.6.0"
  },
  "type": "module",
  "files": [
    "build/src",
    "build/commands",
    "build/index.d.ts",
    "build/index.js"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types.js",
    "./commands": "./build/commands/main.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "index:commands": "adonis-kit index build/commands",
    "copy:templates": "copyfiles \"stubs/**/*\" build",
    "format": "prettier --write .",
    "test": "node --import=./tsnode.esm.js --enable-source-maps bin/test.ts",
    "build": "npm run clean && npm run copy:templates && tsc && npm run index:commands"
  },
  "keywords": [
    "amis",
    "kmola",
    "admin",
    "adonisjs",
    "fullstack",
    "framework"
  ],
  "author": "tmkook",
  "license": "MIT",
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/core": "^6.12.0",
    "@adonisjs/eslint-config": "2.0.0-beta.7",
    "@adonisjs/lucid": "^21.6.1",
    "@adonisjs/prettier-config": "^1.4.0",
    "@adonisjs/tsconfig": "^1.3.0",
    "@japa/assert": "^3.0.0",
    "@japa/file-system": "^2.3.2",
    "@japa/runner": "^3.1.4",
    "@swc/core": "^1.6.3",
    "@types/node": "^20.14.5",
    "adonis-lucid-soft-deletes": "^2.1.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^5.1.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.2",
    "ts-node-maintained": "^10.9.4",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@adonisjs/core": "^6.2.0"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "prettier": "@adonisjs/prettier-config"
}
